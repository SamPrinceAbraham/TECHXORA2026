{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        },
        {
            "src": "*.html",
            "use": "@vercel/static"
        },
        {
            "src": "*.css",
            "use": "@vercel/static"
        },
        {
            "src": "*.js",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(app\\.js|style\\.css|index\\.html)",
            "dest": "/$1"
        },
        {
            "src": "/(admin|volunteer|participant|api|register|login|logout|id-card|test-email)(.*)",
            "dest": "app.py"
        },
        {
            "src": "/",
            "dest": "app.py"
        }
    ],
    "env": {
        "SECRET_KEY": "@secret_key",
        "DATABASE_URL": "@database_url",
        "SUPABASE_URL": "@supabase_url",
        "SUPABASE_KEY": "@supabase_key"
    }
}