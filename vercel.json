{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        },
        {
            "src": "*.html",
            "use": "@vercel/static"
        },
        {
            "src": "*.css",
            "use": "@vercel/static"
        },
        {
            "src": "*.js",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(app\\.js|style\\.css|index\\.html)",
            "dest": "/$1"
        },
        {
            "src": "/(admin|volunteer|participant|api|register|login|logout|id-card|test-email|init-db)(.*)",
            "dest": "app.py"
        },
        {
            "src": "/",
            "dest": "app.py"
        }
    ]
}